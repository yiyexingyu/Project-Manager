<Window
    x:Class="Godot_Manager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Godot_Manager.Helpers"
    xmlns:local="clr-namespace:Godot_Manager"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Godot_Manager.Views"
    xmlns:vm="clr-namespace:Godot_Manager.ViewModels"
    Title="Godot Manager"
    Width="1200"
    Height="750"
    MinWidth="900"
    MinHeight="600"
    Style="{StaticResource ModernWindow}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            CornerRadius="12"
            GlassFrameThickness="0"
            ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <!--  DataTemplates：自动将 ViewModel 类型映射到对应 View  -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ProjectListViewModel}">
            <views:ProjectListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PluginViewModel}">
            <views:PluginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EngineViewModel}">
            <views:EngineView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TemplateViewModel}">
            <views:TemplateView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Border
        Margin="10"
        Background="{StaticResource BackgroundBrush}"
        CornerRadius="16"
        Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <!--  自定义标题栏  -->
                <RowDefinition Height="*" />
                <!--  主内容区  -->
            </Grid.RowDefinitions>

            <!--  ==================== 自定义标题栏 ====================  -->
            <Border
                Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="12,12,0,0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Godot Manager" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button
                            Width="46"
                            Height="32"
                            Click="MinimizeButton_Click"
                            Content="—"
                            Style="{StaticResource IconButton}"
                            ToolTip="最小化" />
                        <Button
                            Width="46"
                            Height="32"
                            Click="MaximizeButton_Click"
                            Content="□"
                            Style="{StaticResource IconButton}"
                            ToolTip="最大化" />
                        <Button
                            Width="46"
                            Height="32"
                            Click="CloseButton_Click"
                            Content="✕"
                            Foreground="{StaticResource ErrorBrush}"
                            Style="{StaticResource IconButton}"
                            ToolTip="关闭" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  ==================== 主内容区：左右分栏 ====================  -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <!--  左侧导航栏  -->
                    <ColumnDefinition Width="*" />
                    <!--  右侧内容区  -->
                </Grid.ColumnDefinitions>

                <!--  ==================== 左侧导航栏 ====================  -->
                <Border
                    Grid.Column="0"
                    Width="{Binding NavBarWidth, FallbackValue=240}"
                    Background="{StaticResource SidebarBrush}">
                    <Border.Resources>
                        <helpers:BooleanToVisibilityConverter x:Key="BoolToVis" />
                    </Border.Resources>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!--  汉堡菜单  -->
                            <RowDefinition Height="*" />
                            <!--  导航项  -->
                            <RowDefinition Height="Auto" />
                            <!--  底部信息  -->
                        </Grid.RowDefinitions>

                        <!--  汉堡菜单（展开/收起按钮）  -->
                        <Button
                            Grid.Row="0"
                            Width="40"
                            Height="40"
                            Margin="10,10,0,4"
                            HorizontalAlignment="Left"
                            Command="{Binding ToggleNavigationCommand}"
                            Foreground="{StaticResource TextOnDarkBrush}"
                            Style="{StaticResource IconButton}">
                            <TextBlock FontSize="18" Text="☰" />
                        </Button>

                        <!--  导航项列表  -->
                        <ItemsControl
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            ItemsSource="{Binding NavigationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                        Style="{StaticResource NavButton}">
                                        <ToggleButton.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    Width="20"
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Icon}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Title}"
                                                    Visibility="{Binding DataContext.IsNavigationExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
                                            </StackPanel>
                                        </ToggleButton.Content>
                                    </ToggleButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  底部版本信息  -->
                        <Border
                            Grid.Row="2"
                            Margin="8,0,8,12"
                            Padding="12,8">
                            <Border.Visibility>
                                <Binding Converter="{StaticResource BoolToVis}" Path="IsNavigationExpanded" />
                            </Border.Visibility>
                            <TextBlock
                                FontSize="11"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="v1.0.0" />
                        </Border>
                    </Grid>
                </Border>

                <!--  ==================== 右侧内容区 ====================  -->
                <Grid Grid.Column="1">
                    <!--  页面内容（通过 DataTemplate 自动切换）  -->
                    <ContentControl Margin="0" Content="{Binding CurrentView}">
                        <ContentControl.Resources>
                            <Style TargetType="UserControl">
                                <Setter Property="Opacity" Value="1" />
                            </Style>
                        </ContentControl.Resources>
                    </ContentControl>

                    <!--  Toast 通知容器（右下角悬浮）  -->
                    <ItemsControl
                        x:Name="ToastContainer"
                        Margin="0,0,20,20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!--  Toast 在代码后置中动态生成  -->
                                <Border />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
