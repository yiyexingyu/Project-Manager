<UserControl
    x:Class="Godot_Manager.Views.TemplateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Godot_Manager.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Godot_Manager.Models"
    d:DesignHeight="600"
    d:DesignWidth="900"
    Background="{StaticResource BackgroundBrush}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  标题  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,16"
            Orientation="Horizontal">
            <TextBlock
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                FontSize="24"
                Text="📝" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="22"
                FontWeight="SemiBold"
                Text="模板管理" />
        </StackPanel>

        <!--  分类 Tab + 工具栏  -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <ToggleButton
                    x:Name="TabProject"
                    Margin="0,0,8,0"
                    Click="TemplateTab_Click"
                    Content="📁 项目模板"
                    IsChecked="True"
                    Style="{StaticResource SecondaryToggleButton}"
                    Tag="项目模板" />
                <ToggleButton
                    x:Name="TabScript"
                    Click="TemplateTab_Click"
                    Content="📄 脚本模板"
                    Style="{StaticResource SecondaryToggleButton}"
                    Tag="脚本模板" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Padding="12,6"
                    Command="{Binding NewTemplateCommand}"
                    Content="➕ 新建"
                    FontSize="13"
                    Style="{StaticResource PrimaryButton}" />
                <Button
                    Padding="12,6"
                    Command="{Binding ImportTemplateCommand}"
                    Content="📥 导入"
                    FontSize="13"
                    Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </Grid>

        <!--  内容区：左右分栏  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!--  左侧：模板列表  -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <!--  项目模板列表  -->
                <ListView
                    x:Name="ProjectTemplateList"
                    ItemsSource="{Binding ProjectTemplates}"
                    Style="{StaticResource ModernListView}">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ProjectTemplate}">
                            <Border
                                Margin="0,0,0,4"
                                Padding="12,10"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                MouseLeftButtonDown="TemplateItem_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding Description}" />
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            Command="{Binding DataContext.SetDefaultCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding Name}"
                                            Content="⭐"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="设为默认" />
                                        <Button
                                            Command="{Binding DataContext.DeleteTemplateCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding Name}"
                                            Content="🗑"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="删除" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!--  脚本模板列表  -->
                <ListView
                    x:Name="ScriptTemplateList"
                    ItemsSource="{Binding ScriptTemplates}"
                    Style="{StaticResource ModernListView}"
                    Visibility="Collapsed">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ScriptTemplate}">
                            <Border
                                Margin="0,0,0,4"
                                Padding="12,10"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                MouseLeftButtonDown="TemplateItem_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Text="{Binding Name}" />
                                            <Border
                                                Margin="6,0,0,0"
                                                Padding="4,1"
                                                Background="{StaticResource BackgroundBrush}"
                                                CornerRadius="4">
                                                <TextBlock
                                                    FontSize="10"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{Binding Language}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding Description}" />
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            Command="{Binding DataContext.SetDefaultCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding Name}"
                                            Content="⭐"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="设为默认" />
                                        <Button
                                            Command="{Binding DataContext.DeleteTemplateCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding Name}"
                                            Content="🗑"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="删除" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!--  右侧：模板预览  -->
            <Border
                Grid.Column="1"
                Padding="16"
                Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="模板预览" />

                    <!--  项目模板预览  -->
                    <StackPanel x:Name="ProjectPreview" Visibility="Collapsed">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="{Binding SelectedProjectTemplate.Name}" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{Binding SelectedProjectTemplate.Description}"
                            TextWrapping="Wrap" />
                        <Border
                            Height="1"
                            Margin="0,8"
                            Background="{StaticResource BorderLightBrush}" />
                        <TextBlock
                            Margin="0,4,0,2"
                            FontSize="13"
                            Text="{Binding SelectedProjectTemplate.CompatibleEngineVersion, StringFormat='适配引擎: Godot {0}'}" />
                        <TextBlock
                            FontSize="13"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="{Binding SelectedProjectTemplate.CreatedAt, StringFormat='创建时间: {0:yyyy-MM-dd}'}" />
                    </StackPanel>

                    <!--  脚本模板预览  -->
                    <StackPanel x:Name="ScriptPreview" Visibility="Collapsed">
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="{Binding SelectedScriptTemplate.Name}" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="12"
                            Foreground="{StaticResource PrimaryBrush}"
                            Text="{Binding SelectedScriptTemplate.Language}" />
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="代码预览" />
                        <Border
                            Padding="10"
                            Background="{StaticResource BackgroundBrush}"
                            CornerRadius="6">
                            <TextBlock
                                FontFamily="Consolas, Courier New"
                                FontSize="12"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding SelectedScriptTemplate.CodePreview}"
                                TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <!--  未选择提示  -->
                    <TextBlock
                        x:Name="NoSelection"
                        Margin="0,40,0,0"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="选择左侧模板查看详情" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
