<UserControl
    x:Class="Godot_Manager.Views.PluginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Godot_Manager.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Godot_Manager.Models"
    d:DesignHeight="600"
    d:DesignWidth="900"
    Background="{StaticResource BackgroundBrush}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  标题  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,16"
            Orientation="Horizontal">
            <TextBlock
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                FontSize="24"
                Text="🔌" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="22"
                FontWeight="SemiBold"
                Text="插件管理" />
        </StackPanel>

        <!--  Tab 切换 + 搜索  -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <ToggleButton
                    x:Name="TabLocal"
                    Margin="0,0,8,0"
                    Click="Tab_Click"
                    Content="📦 本地插件"
                    IsChecked="True"
                    Style="{StaticResource SecondaryToggleButton}"
                    Tag="本地插件" />
                <ToggleButton
                    x:Name="TabOfficial"
                    Margin="0,0,8,0"
                    Click="Tab_Click"
                    Content="🌐 官方插件"
                    Style="{StaticResource SecondaryToggleButton}"
                    Tag="官方插件" />
                <ToggleButton
                    x:Name="TabFavorites"
                    Click="Tab_Click"
                    Content="⭐ 收藏插件"
                    Style="{StaticResource SecondaryToggleButton}"
                    Tag="收藏插件" />
            </StackPanel>

            <TextBox
                Grid.Column="1"
                MaxWidth="250"
                Margin="16,0,0,0"
                Style="{StaticResource ModernTextBox}"
                Tag="搜索插件..."
                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="{Binding CacheStatus}" />
                <Button
                    Padding="10,6"
                    Command="{Binding RefreshOfficialCommand}"
                    Content="🔄 刷新"
                    FontSize="12"
                    Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </Grid>

        <!--  内容区  -->
        <Grid Grid.Row="2">

            <!--  加载中  -->
            <Border
                Padding="40"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="40"
                        Text="⏳" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="16"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="正在加载插件..." />
                </StackPanel>
            </Border>

            <!--  本地插件 Tab  -->
            <ListView
                x:Name="LocalTabView"
                ItemsSource="{Binding LocalPlugins}"
                Style="{StaticResource ModernListView}">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:LocalPlugin}">
                        <Border
                            Margin="0,0,0,4"
                            Padding="12,10"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}" />
                                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,0,12,0"
                                            FontSize="12"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            Text="{Binding Version, StringFormat='v{0}'}" />
                                        <TextBlock
                                            MaxWidth="300"
                                            FontSize="11"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            Text="{Binding InstallPath}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Button
                                        Command="{Binding DataContext.OpenPluginDirCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        Content="📂"
                                        Style="{StaticResource IconButton}"
                                        ToolTip="打开目录" />
                                    <Button
                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding Name}"
                                        Content="⭐"
                                        Style="{StaticResource IconButton}"
                                        ToolTip="收藏" />
                                    <Button
                                        Command="{Binding DataContext.DeletePluginCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        Content="🗑"
                                        Style="{StaticResource IconButton}"
                                        ToolTip="删除" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!--  官方插件 Tab  -->
            <ListView
                x:Name="OfficialTabView"
                ItemsSource="{Binding OfficialPlugins}"
                Style="{StaticResource ModernListView}"
                Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:OfficialPlugin}">
                        <Border
                            Margin="0,0,0,4"
                            Padding="12,10"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="{Binding Title}" />
                                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,0,12,0"
                                            FontSize="12"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding Author}" />
                                        <TextBlock
                                            Margin="0,0,12,0"
                                            FontSize="12"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            Text="{Binding Version, StringFormat='v{0}'}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            Text="{Binding GodotVersion, StringFormat='Godot {0}'}" />
                                    </StackPanel>
                                    <TextBlock
                                        MaxWidth="400"
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding Description}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Button
                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding Title}"
                                        Content="⭐"
                                        Style="{StaticResource IconButton}"
                                        ToolTip="收藏" />
                                    <Button
                                        Padding="10,4"
                                        Command="{Binding DataContext.DownloadPluginCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        Content="⬇ 安装"
                                        FontSize="12"
                                        Style="{StaticResource PrimaryButton}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!--  收藏插件 Tab  -->
            <Grid x:Name="FavoritesTabView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,8,0,8"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="本地收藏" />
                <ListView
                    Grid.Row="1"
                    ItemsSource="{Binding FavoriteLocalPlugins}"
                    Style="{StaticResource ModernListView}" />

                <TextBlock
                    Grid.Row="2"
                    Margin="0,8,0,8"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="官方收藏" />
                <ListView
                    Grid.Row="3"
                    ItemsSource="{Binding FavoriteOfficialPlugins}"
                    Style="{StaticResource ModernListView}">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:OfficialPlugin}">
                            <Border
                                Margin="0,0,0,4"
                                Padding="10,8"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="{Binding Title}" />
                                    <Button
                                        Padding="8,4"
                                        HorizontalAlignment="Right"
                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding Title}"
                                        Content="取消收藏"
                                        FontSize="11"
                                        Style="{StaticResource SecondaryButton}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
