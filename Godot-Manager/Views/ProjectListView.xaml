<UserControl
    x:Class="Godot_Manager.Views.ProjectListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Godot_Manager.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Godot_Manager.Models"
    d:DesignHeight="600"
    d:DesignWidth="900"
    Background="{StaticResource BackgroundBrush}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InverseBooleanConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  
            <!--  标题栏  -->
            <RowDefinition Height="Auto" />  
            <!--  工具栏  -->
            <RowDefinition Height="*" />     
            <!--  内容区  -->
        </Grid.RowDefinitions>

        <!--  ==================== 标题栏 ====================  -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Text="📁" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="项目管理" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding ScanProjectsCommand}"
                    Content="🔄 扫描项目"
                    Style="{StaticResource PrimaryButton}" />
                <Button
                    Command="{Binding NewProjectCommand}"
                    Content="➕ 新建项目"
                    Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </Grid>

        <!--  ==================== 工具栏 ====================  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,12"
            Padding="12"
            Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="300" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  搜索框  -->
                <TextBox
                    Grid.Column="0"
                    Style="{StaticResource ModernTextBox}"
                    Tag="搜索项目名称..."
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <!--  排序下拉  -->
                <ComboBox
                    Grid.Column="1"
                    Width="100"
                    Margin="8,0,0,0"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SortBy}"
                    Style="{StaticResource ModernComboBox}" />

                <!--  引擎版本筛选  -->
                <ComboBox
                    Grid.Column="2"
                    Width="100"
                    Margin="8,0,0,0"
                    ItemsSource="{Binding EngineVersionOptions}"
                    SelectedItem="{Binding FilterEngineVersion}"
                    Style="{StaticResource ModernComboBox}" />

                <!--  视图切换  -->
                <Button
                    Grid.Column="3"
                    Margin="8,0,0,0"
                    Command="{Binding ToggleViewModeCommand}"
                    Style="{StaticResource IconButton}"
                    ToolTip="切换视图">
                    <TextBlock FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="📋" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewMode}" Value="卡片">
                                        <Setter Property="Text" Value="🖼️" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </Grid>
        </Border>

        <!--  ==================== 内容区 ====================  -->
        <Grid Grid.Row="2">

            <!--  加载中  -->
            <Border
                Padding="40"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="40"
                        Text="⏳" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="16"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="正在扫描项目..." />
                </StackPanel>
            </Border>

            <!--  空白状态  -->
            <Border
                Padding="40"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="10"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="48"
                        Text="📂" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="暂无项目" />
                    <TextBlock
                        Margin="0,8,0,16"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="点击「扫描项目」发现本地 Godot 项目，或「新建项目」创建新项目" />
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding ScanProjectsCommand}"
                            Content="🔄 扫描项目"
                            Style="{StaticResource PrimaryButton}" />
                        <Button
                            Command="{Binding NewProjectCommand}"
                            Content="➕ 新建项目"
                            Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  列表视图  -->
            <ListView ItemsSource="{Binding FilteredProjects}" Visibility="Collapsed">
                <ListView.Style>
                    <Style BasedOn="{StaticResource ModernListView}" TargetType="ListView">
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ViewMode}" Value="列表" />
                                    <Condition Binding="{Binding IsLoading}" Value="False" />
                                    <Condition Binding="{Binding IsEmpty}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>

                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:GodotProject}">
                        <Border
                            Margin="0,0,0,4"
                            Padding="12,10"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,0,12,0"
                                            FontSize="12"
                                            Foreground="{StaticResource PrimaryBrush}"
                                            Text="{Binding EngineVersion, StringFormat='Godot {0}'}" />
                                        <TextBlock
                                            MaxWidth="350"
                                            FontSize="11"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            Text="{Binding ProjectPath}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Button
                                        MinWidth="60"
                                        Margin="0,0,6,0"
                                        Padding="10,4"
                                        Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        Content="▶ 打开"
                                        FontSize="12"
                                        Style="{StaticResource PrimaryButton}" />
                                    <Button
                                        Margin="0,0,4,0"
                                        Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        Content="📂"
                                        Style="{StaticResource IconButton}"
                                        ToolTip="打开目录" />
                                    <Button
                                        Command="{Binding DataContext.RemoveFromListCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        Content="🗑"
                                        Style="{StaticResource IconButton}"
                                        ToolTip="移除列表" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!--  卡片视图  -->
            <ItemsControl ItemsSource="{Binding FilteredProjects}" Visibility="Collapsed">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ViewMode}" Value="卡片" />
                                    <Condition Binding="{Binding IsLoading}" Value="False" />
                                    <Condition Binding="{Binding IsEmpty}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:GodotProject}">
                        <Border
                            Width="260"
                            Height="180"
                            Margin="0,0,12,12"
                            MouseEnter="ProjectCard_MouseEnter"
                            MouseLeave="ProjectCard_MouseLeave"
                            Style="{StaticResource CardBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Center"
                                        FontSize="32"
                                        Text="📁" />
                                    <TextBlock
                                        MaxWidth="220"
                                        Margin="0,0,0,4"
                                        HorizontalAlignment="Center"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{StaticResource PrimaryBrush}"
                                        Text="{Binding EngineVersion, StringFormat='Godot {0}'}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="1"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Button
                                        MinWidth="60"
                                        Margin="0,0,6,0"
                                        Padding="12,4"
                                        Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Content="▶ 打开"
                                        FontSize="12"
                                        Style="{StaticResource PrimaryButton}" />
                                    <Button
                                        Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Content="📂"
                                        Style="{StaticResource IconButton}"
                                        ToolTip="打开目录" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
