<UserControl
    x:Class="Godot_Manager.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Godot_Manager.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Godot_Manager.Models"
    xmlns:services="clr-namespace:Godot_Manager.Services"
    d:DesignHeight="600"
    d:DesignWidth="900"
    Background="{StaticResource BackgroundBrush}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:CountToBoolConverter x:Key="CountToBool" />
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource ModernScrollViewer}">
        <StackPanel Margin="24" Orientation="Vertical">

            <!--  ==================== 标题 ====================  -->
            <StackPanel Margin="0,0,0,24" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="24"
                    Text="⚙️" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="应用设置" />
            </StackPanel>

            <!--  ==================== 项目扫描目录配置 ====================  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Style="{StaticResource CardBorder}">
                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="📁 项目扫描目录" />

                    <!--  路径列表  -->
                    <ItemsControl ItemsSource="{Binding ProjectScanPaths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,6"
                                    Padding="12,10"
                                    Background="{StaticResource BackgroundBrush}"
                                    CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton
                                            Grid.Column="0"
                                            Width="20"
                                            Height="20"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsEnabled}"
                                            Style="{StaticResource SecondaryToggleButton}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Text="{Binding Path}" />
                                        <Button
                                            Grid.Column="2"
                                            Padding="8,4"
                                            Command="{Binding DataContext.RemoveProjectPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="✕"
                                            FontSize="12"
                                            Foreground="{StaticResource ErrorBrush}"
                                            Style="{StaticResource IconButton}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  空状态  -->
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="13"
                        Foreground="{StaticResource TextMutedBrush}"
                        Visibility="{Binding ProjectScanPaths.Count, Converter={StaticResource CountToBool}}">
                        尚未配置项目扫描路径，请添加。
                    </TextBlock>

                    <!--  添加按钮  -->
                    <Button
                        Margin="0,4,0,0"
                        HorizontalAlignment="Left"
                        Command="{Binding AddProjectPathCommand}"
                        Content="➕ 添加目录"
                        Style="{StaticResource SecondaryButton}" />
                </StackPanel>
            </Border>

            <!--  ==================== 插件扫描目录配置 ====================  -->
            <Border
                Margin="0,0,0,16"
                Padding="20"
                Style="{StaticResource CardBorder}">
                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="🔌 插件扫描目录" />

                    <ItemsControl ItemsSource="{Binding PluginScanPaths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,6"
                                    Padding="12,10"
                                    Background="{StaticResource BackgroundBrush}"
                                    CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton
                                            Grid.Column="0"
                                            Width="20"
                                            Height="20"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsEnabled}"
                                            Style="{StaticResource SecondaryToggleButton}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Text="{Binding Path}" />
                                        <Button
                                            Grid.Column="2"
                                            Padding="8,4"
                                            Command="{Binding DataContext.RemovePluginPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="✕"
                                            FontSize="12"
                                            Foreground="{StaticResource ErrorBrush}"
                                            Style="{StaticResource IconButton}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="13"
                        Foreground="{StaticResource TextMutedBrush}"
                        Visibility="{Binding PluginScanPaths.Count, Converter={StaticResource CountToBool}}">
                        尚未配置插件扫描路径，请添加。
                    </TextBlock>

                    <Button
                        Margin="0,4,0,0"
                        HorizontalAlignment="Left"
                        Command="{Binding AddPluginPathCommand}"
                        Content="➕ 添加目录"
                        Style="{StaticResource SecondaryButton}" />
                </StackPanel>
            </Border>

            <!--  ==================== 引擎扫描目录配置 ====================  -->
            <Border
                Padding="20"
                Style="{StaticResource CardBorder}">
                <StackPanel Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="⚙️ 引擎扫描目录" />

                    <ItemsControl ItemsSource="{Binding EngineScanPaths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,6"
                                    Padding="12,10"
                                    Background="{StaticResource BackgroundBrush}"
                                    CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ToggleButton
                                            Grid.Column="0"
                                            Width="20"
                                            Height="20"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsEnabled}"
                                            Style="{StaticResource SecondaryToggleButton}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Text="{Binding Path}" />
                                        <Button
                                            Grid.Column="2"
                                            Padding="8,4"
                                            Command="{Binding DataContext.RemoveEnginePathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="✕"
                                            FontSize="12"
                                            Foreground="{StaticResource ErrorBrush}"
                                            Style="{StaticResource IconButton}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="13"
                        Foreground="{StaticResource TextMutedBrush}"
                        Visibility="{Binding EngineScanPaths.Count, Converter={StaticResource CountToBool}}">
                        尚未配置引擎扫描路径，请添加。
                    </TextBlock>

                    <Button
                        Margin="0,4,0,0"
                        HorizontalAlignment="Left"
                        Command="{Binding AddEnginePathCommand}"
                        Content="➕ 添加目录"
                        Style="{StaticResource SecondaryButton}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
