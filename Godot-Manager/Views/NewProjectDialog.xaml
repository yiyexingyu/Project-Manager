<Window
    x:Class="Godot_Manager.Views.NewProjectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:Godot_Manager.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="新建 Godot 项目"
    Width="560"
    Height="520"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border
        Background="{StaticResource SurfaceBrush}"
        BorderBrush="{StaticResource BorderLightBrush}"
        BorderThickness="1"
        CornerRadius="12"
        Effect="{StaticResource DialogShadow}">

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  标题栏  -->
                <RowDefinition Height="Auto" />
                <!--  表单  -->
                <RowDefinition Height="Auto" />
                <!--  按钮  -->
            </Grid.RowDefinitions>

            <!--  ==================== 标题栏 ====================  -->
            <Border
                Grid.Row="0"
                Height="48"
                Background="{StaticResource BackgroundBrush}"
                CornerRadius="12,12,0,0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock
                        Margin="20,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="➕ 新建 Godot 项目" />
                    <Button
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        Content="✕"
                        Style="{StaticResource IconButton}" />
                </Grid>
            </Border>

            <!--  ==================== 表单区域 ====================  -->
            <ScrollViewer
                Grid.Row="1"
                Margin="20,16"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!--  项目名称  -->
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="项目名称 *" />
                    <TextBox
                        Margin="0,0,0,4"
                        Style="{StaticResource ModernTextBox}"
                        Tag="输入项目名称"
                        Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="12"
                        Foreground="{StaticResource ErrorBrush}"
                        Text="{Binding ProjectNameError}"
                        Visibility="{Binding ProjectNameError, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" />

                    <!--  存储路径  -->
                    <TextBlock
                        Margin="0,0,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="存储路径 *" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            Style="{StaticResource ModernTextBox}"
                            Tag="选择或输入项目存储路径"
                            Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="10,6"
                            Command="{Binding BrowsePathCommand}"
                            Content="📂 浏览"
                            FontSize="12"
                            Style="{StaticResource SecondaryButton}" />
                    </Grid>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="12"
                        Foreground="{StaticResource ErrorBrush}"
                        Text="{Binding ProjectPathError}"
                        Visibility="{Binding ProjectPathError, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" />

                    <!--  引擎版本  -->
                    <TextBlock
                        Margin="0,12,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="引擎版本" />
                    <ComboBox
                        Margin="0,0,0,12"
                        ItemsSource="{Binding EngineVersions}"
                        SelectedItem="{Binding SelectedEngineVersion}"
                        Style="{StaticResource ModernComboBox}" />

                    <!--  项目模板  -->
                    <TextBlock
                        Margin="0,12,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="项目模板" />
                    <ComboBox
                        Margin="0,0,0,12"
                        ItemsSource="{Binding ProjectTemplates}"
                        SelectedItem="{Binding SelectedTemplate}"
                        Style="{StaticResource ModernComboBox}" />

                    <!--  脚本模板  -->
                    <TextBlock
                        Margin="0,12,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="脚本模板" />
                    <ComboBox
                        Margin="0,0,0,12"
                        ItemsSource="{Binding ScriptTemplates}"
                        SelectedItem="{Binding SelectedScriptTemplate}"
                        Style="{StaticResource ModernComboBox}" />

                    <!--  插件选择  -->
                    <TextBlock
                        Margin="0,12,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="插件选择" />
                    <Border
                        MaxHeight="150"
                        BorderBrush="{StaticResource BorderLightBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <ItemsControl ItemsSource="{Binding PluginItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox
                                        Margin="8,4"
                                        Content="{Binding Name}"
                                        IsChecked="{Binding IsSelected}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!--  ==================== 底部按钮 ====================  -->
            <Border
                Grid.Row="2"
                Padding="20,12"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Margin="0,0,12,0"
                            Command="{Binding CancelCommand}"
                            Content="取消"
                            Style="{StaticResource SecondaryButton}" />
                        <Button
                            Command="{Binding CreateProjectCommand}"
                            Content="创建项目"
                            IsEnabled="{Binding IsCreating, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, FallbackValue=True}"
                            Style="{StaticResource PrimaryButton}" />
                    </StackPanel>

                    <!--  创建中指示器  -->
                    <Border
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsCreating, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                FontSize="14"
                                Text="⏳" />
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource PrimaryBrush}"
                                Text="正在创建项目..." />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
